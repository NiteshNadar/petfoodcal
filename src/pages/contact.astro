---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us: Pet Food Nutrition Inquiries | petfoodcal" 
  description="Get in touch with the petfoodcal team. Send us your feedback, questions about our dog and cat feeding formulas, or general inquiries."
  canonicalUrl="https://petfoodcal.vercel.app/contact"
>
  <!-- Hero Banner -->
  <section class="bg-canvas-soft border-b border-hairline" style="padding: 80px 24px 64px;">
    <div class="max-w-[700px] mx-auto text-center">
      <span class="font-mono text-[11px] uppercase tracking-wider text-link inline-block" style="margin-bottom: 12px;">Get In Touch</span>
      <h1 class="display-lg font-semibold tracking-tight text-ink" style="margin-bottom: 16px;">Contact Our Team</h1>
      <p class="text-body leading-relaxed" style="font-size: 16px; max-width: 520px; margin: 0 auto;">
        Have feedback, questions about our mathematical nutrition models, or feature requests? We would love to hear from you.
      </p>
    </div>
  </section>

  <!-- Content & Contact Form -->
  <section class="bg-canvas" style="padding: 64px 24px 80px;">
    <div class="max-w-[600px] mx-auto">
      
      <!-- Contact Form Card -->
      <div class="bg-canvas-soft border border-hairline rounded-lg shadow-subtle-level-2" style="padding: 32px; margin-bottom: 32px;">
        <h2 class="display-sm font-semibold text-ink" style="margin-bottom: 24px; font-size: 20px;">Send a Message</h2>
        
        <form id="contact-form" style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Name Input -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="contact-name" class="font-mono text-[12px] uppercase tracking-wider text-body font-semibold">Your Name</label>
            <input 
              type="text" 
              id="contact-name" 
              name="name" 
              required 
              placeholder="e.g. John Doe"
              class="w-full bg-canvas text-ink border border-hairline rounded-sm px-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 ease-out-quart"
              style="height: 40px; font-size: 14px; transition: all 0.15s ease-out;"
            />
          </div>

          <!-- Email Input -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="contact-email" class="font-mono text-[12px] uppercase tracking-wider text-body font-semibold">Email Address</label>
            <input 
              type="email" 
              id="contact-email" 
              name="email" 
              required 
              placeholder="e.g. john@example.com"
              class="w-full bg-canvas text-ink border border-hairline rounded-sm px-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 ease-out-quart"
              style="height: 40px; font-size: 14px; transition: all 0.15s ease-out;"
            />
          </div>

          <!-- Subject Input -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="contact-subject" class="font-mono text-[12px] uppercase tracking-wider text-body font-semibold">Subject</label>
            <input 
              type="text" 
              id="contact-subject" 
              name="subject" 
              required 
              placeholder="e.g. Calculator feedback, Business query"
              class="w-full bg-canvas text-ink border border-hairline rounded-sm px-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 ease-out-quart"
              style="height: 40px; font-size: 14px; transition: all 0.15s ease-out;"
            />
          </div>

          <!-- Message Input -->
          <div style="display: flex; flex-direction: column; gap: 8px;">
            <label for="contact-message" class="font-mono text-[12px] uppercase tracking-wider text-body font-semibold">Message</label>
            <textarea 
              id="contact-message" 
              name="message" 
              rows="5" 
              required 
              placeholder="How can we help you?"
              class="w-full bg-canvas text-ink border border-hairline rounded-sm p-4 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary/20 ease-out-quart"
              style="font-size: 14px; line-height: 1.6; transition: all 0.15s ease-out; resize: vertical;"
            ></textarea>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            class="inline-flex items-center justify-center rounded-full bg-primary text-on-primary text-[14px] font-medium shadow-subtle-level-2 hover:bg-primary/90 active:scale-[0.98] cursor-pointer select-none focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/25" 
            style="height: 44px; margin-top: 8px; transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);"
          >
            Submit Message
          </button>
        </form>

        <!-- Success Toast Notification (Hidden by default, fixed position bottom-right) -->
        <div 
          id="success-toast" 
          class="hidden fixed bottom-6 right-6 z-50 max-w-sm w-[calc(100vw-48px)] sm:w-80 bg-canvas border border-hairline rounded-lg shadow-subtle-level-3" 
          style="padding: 16px; border-left: 4px solid var(--color-link); opacity: 0; transform: translateY(16px); transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);"
        >
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0" style="margin-top: 2px;">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-link opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-link"></span>
              </span>
            </div>
            <div class="flex-grow">
              <h4 class="font-sans font-semibold text-ink text-[13px] leading-tight">Message Sent</h4>
              <p class="text-body text-[12px] leading-normal" style="margin-top: 4px;">
                Thank you! Your message was submitted successfully.
              </p>
            </div>
            <button 
              type="button" 
              id="close-toast-btn" 
              class="text-mute hover:text-ink cursor-pointer focus:outline-none" 
              style="padding: 2px; line-height: 1;"
              aria-label="Close notification"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
        </div>
      </div>

      <!-- Quick Contact Info -->
      <div class="border-t border-hairline" style="padding-top: 32px; display: flex; flex-direction: column; gap: 16px; align-items: center; text-center;">
        <span class="font-mono text-[12px] uppercase tracking-wider text-body font-semibold">Direct Email Channel</span>
        <p class="text-body" style="font-size: 14px; margin: 0;">
          Prefer writing directly? Email us at: <a href="mailto:nadarnitesh32@gmail.com" class="text-link hover:underline font-medium">nadarnitesh32@gmail.com</a>
        </p>
      </div>

    </div>
  </section>

  <!-- Client-side script for Form Submission Handling -->
  <script is:inline>
    const initContactForm = () => {
      const form = document.getElementById('contact-form');
      const toast = document.getElementById('success-toast');
      const closeBtn = document.getElementById('close-toast-btn');
      
      let toastTimeout;
      
      const hideToast = () => {
        if (toast) {
          toast.style.opacity = '0';
          toast.style.transform = 'translateY(16px)';
          setTimeout(() => {
            toast.classList.add('hidden');
          }, 300);
        }
      };

      if (form && toast) {
        form.addEventListener('submit', (e) => {
          e.preventDefault();
          
          // Reset form fields
          form.reset();
          
          // Clear any active timeout
          if (toastTimeout) clearTimeout(toastTimeout);
          
          // Show toast with slide-up transition
          toast.classList.remove('hidden');
          // Trigger browser layout flow to enable transitions
          void toast.offsetWidth;
          toast.style.opacity = '1';
          toast.style.transform = 'translateY(0)';
          
          // Auto hide after 5 seconds
          toastTimeout = setTimeout(hideToast, 5000);
        });
      }
      
      if (closeBtn) {
        closeBtn.addEventListener('click', () => {
          if (toastTimeout) clearTimeout(toastTimeout);
          hideToast();
        });
      }
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initContactForm);
    } else {
      initContactForm();
    }
  </script>
</Layout>
