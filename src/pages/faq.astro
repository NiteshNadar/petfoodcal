---
// src/pages/faq.astro
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: "How much wet food should I feed my dog?",
    answer: "The amount depends on your dog's weight, age, body shape, and activity level. Wet food contains a lot of water, so the serving weight is usually higher than dry food. Choose \"Wet or canned food\" in the calculator to get a daily gram amount and meal split."
  },
  {
    question: "How long will my pet food last?",
    answer: "After you calculate the daily food amount, enter your bag size in pounds or kilograms. The calculator divides the bag weight by the daily amount and estimates when you may need to buy more."
  },
  {
    question: "Why is the wet food amount higher than kibble?",
    answer: "Wet food contains more water, while dry food is more concentrated. That means the gram amount for wet food can look bigger even when the calories are similar."
  },
  {
    question: "Does age change the amount?",
    answer: "Yes. Puppies and kittens usually need more food because they are growing. Adult pets usually need a steady amount. Senior pets may need less, depending on activity and body shape."
  },
  {
    question: "How much food should I feed my dog?",
    answer: "Start with your dog's weight, age, size, body shape, activity level, and whether they are spayed or neutered. The calculator turns those answers into a daily amount in grams, ounces, and estimated cups."
  },
  {
    question: "How much dry food should I feed my cat?",
    answer: "Choose \"Cat,\" select dry kibble, and enter your cat's details. The calculator uses a cat dry-food cup estimate of 90g per cup, but weighing in grams is still more accurate."
  },
  {
    question: "Can I use this for raw-fed cats?",
    answer: "Yes. Choose \"Cat\" and select either ready-made raw or DIY raw 80/10/10. The calculator gives a daily amount and, for DIY raw, shows the meat, bone, liver, and other organ split."
  },
  {
    question: "How many wet food pouches should my cat eat?",
    answer: "For cats, the calculator uses a standard 85g pouch as an estimate. Your food label may be different, so use the gram amount as the main number."
  },
  {
    question: "Can I use this for different food types?",
    answer: "Yes. It supports raw, dry kibble, wet food, home-cooked food, and a dry-plus-wet mix."
  },
  {
    question: "Can I use this for raw-fed dogs?",
    answer: "Yes. Choose ready-made raw for complete raw food, or DIY raw 80/10/10 if you want the calculator to split the amount into meat, bone, liver, and other organ weights."
  }
];

// Generate JSON-LD Schema for SEO
const schemaData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<Layout 
  title="FAQ: Dog & Cat Food Calculator Questions | petfoodcal" 
  description="Find answers to common queries about our dog food calculator and cat food calculator models. Learn about raw dog food calculator ratios, spay/neuter factors, and dry/wet food splits."
  canonicalUrl="https://petfoodcal.vercel.app/faq"
>
  <!-- Main FAQ Section -->
  <section class="bg-canvas-soft border-t border-hairline relative z-20" style="padding: 80px 24px 96px; min-height: 100vh;">
    <div class="max-w-[800px] mx-auto">
      <div class="text-center" style="margin-bottom: 40px;">
        <span class="font-mono text-[12px] uppercase tracking-wider text-body inline-block" style="margin-bottom: 12px;">Common Feeding Questions</span>
      <h1 class="display-sm font-semibold text-ink" style="font-size: 28px; letter-spacing: 0;">
          Common questions about pet food portions
        </h1>
      </div>

      <div id="home-faq-list" style="display: flex; flex-direction: column; gap: 12px;">
        {faqs.map((faq, index) => {
          const uniqueId = `faq-${index}`;
          return (
            <div class="home-faq-item bg-canvas border border-hairline rounded-md overflow-hidden shadow-subtle-level-1">
              <button
                type="button"
                class="home-faq-btn w-full text-left flex items-center justify-between font-sans font-medium text-ink cursor-pointer select-none focus:outline-none focus-visible:bg-canvas-soft focus-visible:ring-2 focus-visible:ring-primary/20"
                style="padding: 16px 20px; font-size: 14px; line-height: 1.5; transition: background-color 0.15s ease-out;"
                aria-expanded="false"
                aria-controls={`faq-answer-${uniqueId}`}
                id={`faq-btn-${uniqueId}`}
              >
                <span style="padding-right: 16px;">{faq.question}</span>
                <svg class="home-faq-chevron w-4 h-4 text-mute flex-shrink-0" style="transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div
                id={`faq-answer-${uniqueId}`}
                class="home-faq-answer"
                style="display: grid; grid-template-rows: 0fr; opacity: 0; transition: grid-template-rows 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.25s ease-out;"
                aria-labelledby={`faq-btn-${uniqueId}`}
                role="region"
              >
                <div class="overflow-hidden">
                  <div class="text-body" style="padding: 4px 20px 20px; font-size: 14px; line-height: 1.7; border-top: 1px solid rgba(235, 235, 235, 0.5);">
                    <p>{faq.answer}</p>
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Inject FAQ JSON-LD Structured Data Schema in Head -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

  <!-- Client-Side FAQ Accordion Script -->
  <script is:inline>
    const initFaq = () => {
      const faqButtons = document.querySelectorAll('.home-faq-btn');
      
      faqButtons.forEach(button => {
        button.addEventListener('click', () => {
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          button.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
        });

        // Hover feedback
        button.addEventListener('mouseenter', () => {
          if (button.getAttribute('aria-expanded') !== 'true') {
            button.style.backgroundColor = 'var(--color-canvas-soft)';
          }
        });
        button.addEventListener('mouseleave', () => {
          button.style.backgroundColor = '';
        });
      });
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFaq);
    } else {
      initFaq();
    }
  </script>

  <style>
    /* FAQ Accordion Animation */
    button[aria-expanded="true"] + .home-faq-answer {
      grid-template-rows: 1fr !important;
      opacity: 1 !important;
    }
    button[aria-expanded="true"] .home-faq-chevron {
      transform: rotate(180deg);
    }
    button[aria-expanded="true"] {
      background-color: var(--color-canvas-soft);
    }

    /* FAQ item hover lift */
    .home-faq-item {
      transition: box-shadow 0.2s ease-out;
    }
    .home-faq-item:hover {
      box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.08) inset, 0 2px 4px rgba(0, 0, 0, 0.04);
    }

    /* Respect reduced motion */
    @media (prefers-reduced-motion: reduce) {
      .home-faq-answer {
        transition: none !important;
      }
      .home-faq-chevron {
        transition: none !important;
      }
    }
  </style>
</Layout>
