---
// src/pages/404.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404: Page Not Found | petfoodcal" 
  description="The requested page could not be found on petfoodcal. Return to our free pet food calculator."
  canonicalUrl="https://petfoodcal.vercel.app/404"
>
  <section class="min-h-[70vh] flex flex-col items-center justify-center" style="padding: 64px 24px;">
    <div class="max-w-[500px] w-full text-center" style="display: flex; flex-direction: column; gap: 24px; align-items: center;">
      <h1 class="display-xl font-bold tracking-tight text-ink">404.</h1>
      <p class="text-body" style="font-size: 16px; max-width: 400px;">
        The page you are looking for has been moved, renamed, or does not exist.
      </p>

      <!-- Terminal Mockup -->
      <div class="bg-primary text-on-primary rounded-md text-left font-mono shadow-subtle-level-4 border border-hairline-strong/30 max-w-md w-full" style="padding: 20px; font-size: 13px;">
        <div class="flex items-center" style="gap: 6px; margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid rgba(255, 255, 255, 0.1);">
          <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
          <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
          <span class="text-white/40" style="font-size: 12px; margin-left: 8px;">bash - guest@petfoodcal</span>
        </div>
        <div style="display: flex; flex-direction: column; gap: 6px;">
          <p class="text-white/40">$ curl -I https://petfoodcal.vercel.app/this-page</p>
          <p class="text-red-400 font-semibold">HTTP/1.1 404 Not Found</p>
          <p class="text-white/50">Content-Type: text/html</p>
          <p class="text-white/50">Cache-Control: no-cache, no-store</p>
          <p class="text-white/40">$ cd /calculator</p>
          <p class="text-green-400 font-semibold animate-pulse">_ Ready to return home...</p>
        </div>
      </div>

      <div class="flex justify-center" style="padding-top: 8px; gap: 16px;">
        <a href="/" class="inline-flex items-center justify-center rounded-full bg-primary text-on-primary text-[14px] font-medium shadow-subtle-level-2 active:scale-[0.97]" style="height: 44px; padding: 0 24px; transition: all 0.15s ease-out;">
          Return to Calculator
        </a>
        <a href="/about" class="inline-flex items-center justify-center rounded-full border border-hairline bg-canvas text-ink text-[14px] font-medium active:scale-[0.97]" style="height: 44px; padding: 0 24px; transition: all 0.15s ease-out;">
          Learn About Us
        </a>
      </div>
    </div>
  </section>
</Layout>
