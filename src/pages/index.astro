---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Calculator from '../components/Calculator.astro';

const helpCards = [
  {
    title: 'Start with a daily amount',
    text: 'Enter your pet details and get a clear gram amount for the whole day.',
  },
  {
    title: 'Split it into meals',
    text: 'See how much to serve in the morning, evening, or three smaller meals.',
  },
  {
    title: 'Plan your next food order',
    text: 'Add your bag size and estimate how many days of food you have left.',
  },
];

const faqs = [
  {
    question: 'Is this a replacement for my vet?',
    answer: 'No. Use this as a helpful starting point. If your pet is pregnant, ill, underweight, overweight, or on a medical diet, ask your vet before changing food amounts.',
  },
  {
    question: 'Should I measure in cups or grams?',
    answer: 'Grams are better. Cups are only an estimate because every food has a different shape and density.',
  },
  {
    question: 'How often should I adjust the amount?',
    answer: 'Check your pet body shape and weight every 2 to 4 weeks. Adjust slowly if they are gaining or losing too much.',
  },
];
---

<Layout
  title="Pet Food Calculator - Simple Dog & Cat Feeding Amounts | petfoodcal"
  description="Use this free pet food calculator to estimate daily food amounts for dogs and cats. Get grams, cups, meal splits, and food bag duration in plain English."
>
  <section class="bg-canvas border-b border-hairline" style="padding: 72px 24px 48px;">
    <div class="max-w-[1120px] mx-auto grid grid-cols-1 lg:grid-cols-[1fr_360px]" style="gap: 40px; align-items: end;">
      <div>
        <span class="font-mono text-[12px] uppercase tracking-wider text-link font-semibold">Dog and cat feeding help</span>
        <h1 class="font-sans font-semibold text-ink" style="font-size: clamp(38px, 6vw, 64px); line-height: 1.02; margin: 14px 0 18px; max-width: 760px;">
          Know how much food to give your pet each day.
        </h1>
        <p class="text-body" style="font-size: 18px; line-height: 1.7; max-width: 680px;">
          A simple calculator for dogs and cats. Choose the food type, enter your pet details, and get a daily amount you can actually understand.
        </p>
        <div class="flex flex-wrap" style="gap: 12px; margin-top: 28px;">
          <a href="#calculator-anchor" class="inline-flex items-center justify-center rounded-sm bg-primary text-on-primary text-[15px] font-semibold shadow-subtle-level-2" style="height: 46px; padding: 0 22px;">
            Use the calculator
          </a>
          <a href="/how-it-works" class="inline-flex items-center justify-center rounded-sm border border-hairline bg-canvas text-ink text-[15px] font-semibold" style="height: 46px; padding: 0 22px;">
            See how it works
          </a>
        </div>
      </div>

      <div class="bg-canvas-soft border border-hairline rounded-lg shadow-subtle-level-2" style="padding: 24px;">
        <div class="font-mono uppercase tracking-wider text-link font-semibold" style="font-size: 12px;">Quick example</div>
        <div style="margin-top: 18px;">
          <div class="text-ink font-semibold" style="font-size: 42px; line-height: 1;">250g</div>
          <p class="text-body" style="font-size: 14px; line-height: 1.6; margin-top: 8px;">daily food amount</p>
        </div>
        <div class="grid grid-cols-2" style="gap: 12px; margin-top: 22px;">
          <div class="bg-canvas border border-hairline rounded-sm" style="padding: 14px;">
            <div class="font-semibold text-ink">2 meals</div>
            <div class="text-mute" style="font-size: 13px; margin-top: 4px;">morning and evening</div>
          </div>
          <div class="bg-canvas border border-hairline rounded-sm" style="padding: 14px;">
            <div class="font-semibold text-ink">125g</div>
            <div class="text-mute" style="font-size: 13px; margin-top: 4px;">each meal</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="calculator-anchor" class="bg-canvas-soft" style="padding: 56px 24px;">
    <Calculator />
  </section>

  <section class="bg-canvas border-t border-hairline" style="padding: 80px 24px;">
    <div class="max-w-[1120px] mx-auto">
      <div class="max-w-[680px]" style="margin-bottom: 32px;">
        <span class="font-mono text-[12px] uppercase tracking-wider text-link font-semibold">What you get</span>
        <h2 class="font-sans font-semibold text-ink" style="font-size: clamp(28px, 4vw, 40px); line-height: 1.15; margin-top: 12px;">
          Clear feeding numbers without brand pressure.
        </h2>
        <p class="text-body" style="font-size: 16px; line-height: 1.7; margin-top: 12px;">
          The calculator does not sell food, push a subscription, or ask for your email. It just gives you a practical starting amount.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 18px;">
        {helpCards.map((card) => (
          <div class="bg-canvas-soft border border-hairline rounded-md shadow-subtle-level-1" style="padding: 24px;">
            <h3 class="font-semibold text-ink" style="font-size: 18px; line-height: 1.35;">{card.title}</h3>
            <p class="text-body" style="font-size: 14px; line-height: 1.7; margin-top: 10px;">{card.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-canvas-soft border-t border-hairline" style="padding: 80px 24px;">
    <div class="max-w-[960px] mx-auto grid grid-cols-1 lg:grid-cols-[320px_1fr]" style="gap: 40px;">
      <div>
        <span class="font-mono text-[12px] uppercase tracking-wider text-link font-semibold">Plain-English guide</span>
        <h2 class="font-sans font-semibold text-ink" style="font-size: 30px; line-height: 1.2; margin-top: 12px;">How to use the result</h2>
        <p class="text-body" style="font-size: 15px; line-height: 1.7; margin-top: 12px;">
          Treat the number as a starting point, then watch your pet. Healthy feeding is about the amount, body shape, energy, and regular check-ins.
        </p>
      </div>

      <div class="bg-canvas border border-hairline rounded-lg shadow-subtle-level-2" style="padding: 28px;">
        <ol class="text-body" style="display: flex; flex-direction: column; gap: 18px; list-style-position: inside; font-size: 15px; line-height: 1.7;">
          <li><strong class="text-ink">Weigh the food when you can.</strong> Cups are convenient, but grams are more accurate.</li>
          <li><strong class="text-ink">Change slowly.</strong> If you need to adjust food, do it gradually over several days.</li>
          <li><strong class="text-ink">Watch body shape.</strong> You should usually feel ribs easily without seeing sharp bones.</li>
          <li><strong class="text-ink">Ask a vet for special cases.</strong> Puppies, kittens, seniors, pregnant pets, and pets with health problems may need a custom plan.</li>
        </ol>
      </div>
    </div>
  </section>

  <section class="bg-canvas border-t border-hairline" style="padding: 80px 24px;">
    <div class="max-w-[960px] mx-auto">
      <div class="text-center" style="margin-bottom: 32px;">
        <span class="font-mono text-[12px] uppercase tracking-wider text-link font-semibold">Common questions</span>
        <h2 class="font-sans font-semibold text-ink" style="font-size: 30px; line-height: 1.2; margin-top: 12px;">Quick answers before you calculate</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3" style="gap: 18px;">
        {faqs.map((faq) => (
          <div class="bg-canvas-soft border border-hairline rounded-md shadow-subtle-level-1" style="padding: 22px;">
            <h3 class="font-semibold text-ink" style="font-size: 16px; line-height: 1.4;">{faq.question}</h3>
            <p class="text-body" style="font-size: 14px; line-height: 1.7; margin-top: 10px;">{faq.answer}</p>
          </div>
        ))}
      </div>

      <div class="text-center" style="margin-top: 32px;">
        <a href="/faq" class="inline-flex items-center justify-center rounded-sm border border-hairline bg-canvas text-ink text-[14px] font-semibold" style="height: 42px; padding: 0 18px;">
          Read all questions
        </a>
      </div>
    </div>
  </section>
</Layout>
