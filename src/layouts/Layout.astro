---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
}

const {
	title = 'Dog Food Calculator: Free Pet Food Feeding Guide | petfoodcal',
	description = 'Free, brand-neutral pet food calculator. Optimize raw, kibble, wet, and homemade diets for dogs and cats. Calculate grams, cups, kcal, and bag lifespan.',
	canonicalUrl = 'https://petfoodcal.com',
	ogImage = 'https://petfoodcal.com/images/og-image.jpg',
} = Astro.props;

// For active nav-link indication
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="petfoodcal" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalUrl} />
		<meta name="robots" content="index, follow" />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:site_name" content="petfoodcal" />
		<meta property="og:locale" content="en_US" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalUrl} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={ogImage} />

		<!-- Google Analytics (gtag.js) -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-FD463JN12Z"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-FD463JN12Z');
		</script>
	</head>
	<body class="bg-canvas-soft text-ink font-sans min-h-screen flex flex-col antialiased">
		<!-- Header (Vercel-like Navbar) -->
		<header class="sticky top-0 z-50 w-full border-b border-hairline bg-canvas" style="height: 64px;">
			<div class="max-w-[1400px] h-full mx-auto flex items-center justify-between" style="padding: 0 24px;">
				<!-- Brand Logo -->
				<a href="/" class="nav-logo flex items-center gap-2.5 group" aria-label="petfoodcal Home">
					<img src="/favicon.svg" alt="petfoodcal logo" class="w-8 h-8" />
					<span class="font-sans font-semibold text-ink select-none" style="font-size: 20px; letter-spacing: -0.6px;">
						petfoodcal
					</span>
				</a>

				<!-- Desktop Nav Links -->
				<nav class="hidden lg:flex items-center" style="gap: 4px;" aria-label="Main Navigation">
					<a href="/" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						Calculate Portions
					</a>
					<a href="/about" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/about' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						About Us
					</a>
					<a href="/how-it-works" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/how-it-works' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						How It Works
					</a>
					<a href="/faq" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/faq' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						FAQ
					</a>
					<a href="/contact" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/contact' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						Contact
					</a>
					<a href="/privacy" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/privacy' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						Privacy
					</a>
					<a href="/terms" class={`nav-link rounded-full text-[13px] font-normal focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none ${currentPath === '/terms' ? 'text-ink bg-canvas-soft-2 font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft-2/50'}`} style="padding: 6px 10px; transition: all 0.15s ease-out;">
						Terms
					</a>
				</nav>

				<!-- Desktop CTAs -->
				<div class="hidden lg:flex items-center" style="gap: 12px;">
					<a href="/#calculator-anchor" class="nav-cta-primary inline-flex items-center justify-center rounded-sm bg-primary text-on-primary text-[14px] font-medium focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none" style="height: 32px; padding: 0 16px; transition: all 0.15s ease-out;">
						Calculate Portions
					</a>
				</div>

				<!-- Mobile Menu Button -->
				<button id="mobile-menu-btn" class="lg:hidden flex items-center justify-center rounded-sm text-body hover:text-ink focus:outline-none focus-visible:ring-2 focus-visible:ring-primary/25" style="padding: 10px;" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
					<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
					</svg>
				</button>
			</div>

			<!-- Mobile Nav Drawer -->
			<div id="mobile-nav" class="hidden absolute left-0 w-full bg-canvas border-b border-hairline shadow-subtle-level-3 lg:hidden" style="top: 64px; transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);">
				<nav class="flex flex-col" style="padding: 16px; gap: 4px;" aria-label="Mobile Navigation">
					<a href="/" class={`rounded-sm text-[14px] ${currentPath === '/' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">Calculate Portions</a>
					<a href="/about" class={`rounded-sm text-[14px] ${currentPath === '/about' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">About Us</a>
					<a href="/how-it-works" class={`rounded-sm text-[14px] ${currentPath === '/how-it-works' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">How It Works</a>
					<a href="/faq" class={`rounded-sm text-[14px] ${currentPath === '/faq' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">FAQ</a>
					<a href="/contact" class={`rounded-sm text-[14px] ${currentPath === '/contact' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">Contact Us</a>
					<div style="height: 1px; background: var(--color-hairline); margin: 8px 0;"></div>
					<a href="/privacy" class={`rounded-sm text-[14px] ${currentPath === '/privacy' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">Privacy Policy</a>
					<a href="/terms" class={`rounded-sm text-[14px] ${currentPath === '/terms' ? 'text-ink bg-canvas-soft font-medium' : 'text-body hover:text-ink hover:bg-canvas-soft'} focus-visible:bg-canvas-soft focus-visible:outline-none`} style="padding: 10px 12px; transition: all 0.15s ease-out;">Terms & Conditions</a>
					<a href="/#calculator-anchor" class="inline-flex items-center justify-center rounded-sm bg-primary text-on-primary text-[14px] font-medium hover:bg-primary/90 focus-visible:ring-2 focus-visible:ring-primary/25 focus-visible:outline-none" style="height: 44px; margin: 8px 12px 0; transition: all 0.15s ease-out;">Calculate Portions</a>
				</nav>
			</div>
		</header>

		<!-- Main Layout Slot -->
		<main class="flex-grow">
			<slot />
		</main>

		<!-- Footer -->
		<footer class="bg-canvas border-t border-hairline" style="padding: 48px 24px;">
			<div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
				<!-- Brand Info -->
				<div class="flex flex-col items-center md:items-start text-center md:text-left">
					<a href="/" class="flex items-center gap-2.5 group" style="margin-bottom: 8px;" aria-label="petfoodcal Home">
						<span class="font-sans font-semibold text-ink" style="font-size: 18px; letter-spacing: -0.5px;">
							petfoodcal
						</span>
					</a>
					<p class="text-mute leading-relaxed" style="font-size: 13px; max-width: 320px;">
						Calculate accurate daily feeding portions with our free, brand-neutral, and science-backed pet food calculator.
					</p>
				</div>

				<!-- Navigation & Copyright -->
				<div class="flex flex-col items-center md:items-end gap-4 text-mute text-right" style="font-size: 13px;">
					<div class="flex flex-wrap justify-center md:justify-end gap-x-6 gap-y-2">
						<a href="/about" class="footer-link text-body hover:text-ink">About Us</a>
						<a href="/how-it-works" class="footer-link text-body hover:text-ink">How It Works</a>
						<a href="/faq" class="footer-link text-body hover:text-ink">FAQ</a>
						<a href="/contact" class="footer-link text-body hover:text-ink">Contact Us</a>
						<a href="/privacy" class="footer-link text-body hover:text-ink">Privacy Policy</a>
						<a href="/terms" class="footer-link text-body hover:text-ink">Terms & Conditions</a>
					</div>
					<div style="font-size: 12px;">
						&copy; {new Date().getFullYear()} petfoodcal. All rights reserved.
					</div>
				</div>
			</div>
		</footer>

		<!-- Mobile Menu Script -->
		<script is:inline>
			const menuBtn = document.getElementById('mobile-menu-btn');
			const mobileNav = document.getElementById('mobile-nav');
			const menuIcon = document.getElementById('menu-icon');

			if (menuBtn && mobileNav) {
				menuBtn.addEventListener('click', () => {
					const isExpanded = menuBtn.getAttribute('aria-expanded') === 'true';
					menuBtn.setAttribute('aria-expanded', !isExpanded);
					mobileNav.classList.toggle('hidden');

					if (!isExpanded) {
						// Close icon
						menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
					} else {
						// Hamburger icon
						menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
					}
				});

				// Close mobile nav on click of links
				const mobileLinks = mobileNav.querySelectorAll('a');
				mobileLinks.forEach(link => {
					link.addEventListener('click', () => {
						mobileNav.classList.add('hidden');
						menuBtn.setAttribute('aria-expanded', 'false');
						menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
					});
				});
			}
		</script>

		<style is:global>
			/* Footer link transitions */
			.footer-link {
				transition: color 0.15s ease-out;
			}

			/* Nav logo hover */
			.nav-logo:hover svg {
				transform: scale(1.05);
			}

			/* Nav CTA hover states */
			.nav-cta-secondary:hover {
				background-color: var(--color-canvas-soft);
			}
			.nav-cta-secondary:active {
				transform: scale(0.98);
			}
			.nav-cta-primary:hover {
				opacity: 0.92;
			}
			.nav-cta-primary:active {
				transform: scale(0.98);
			}

			/* Reduced motion */
			@media (prefers-reduced-motion: reduce) {
				.nav-logo svg,
				.nav-cta-secondary,
				.nav-cta-primary,
				.footer-link {
					transition: none !important;
				}
			}
		</style>
	</body>
</html>
